<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
    Penova for Mac is distributed direct-from-website with Developer
    ID + notarization, NOT through the Mac App Store. The App Sandbox
    is therefore not required (and would force XPC service indirection
    for Sparkle's auto-update path), so we omit it. The hardened
    runtime (project.yml: ENABLE_HARDENED_RUNTIME = YES) is what
    Apple's notary service requires for Gatekeeper trust.

    Entitlements declared here:
      • com.apple.security.network.client — Sparkle fetches the
        appcast.xml feed + downloads update DMGs; Sign in with Apple
        contacts Apple's auth service.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
