# The Xcode project is generated from project.yml by xcodegen.
# Re-run `xcodegen` after editing project.yml. We still commit the
# generated .xcodeproj so open-from-Xcode works without a toolchain,
# but ignore user-specific scheme data.
Penova.xcodeproj/xcuserdata/
Penova.xcodeproj/project.xcworkspace/xcuserdata/
Penova.xcodeproj/project.xcworkspace/xcshareddata/

